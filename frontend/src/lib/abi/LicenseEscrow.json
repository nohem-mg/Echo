{
  "abi": [
    {
      "type": "constructor",
      "inputs": [{ "name": "_registry", "type": "address" }],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "createListing",
      "inputs": [
        { "name": "trackId", "type": "bytes32" },
        { "name": "price", "type": "uint256" },
        { "name": "licenseType", "type": "uint8" },
        { "name": "duration", "type": "uint8" }
      ],
      "outputs": [{ "name": "listingId", "type": "bytes32" }],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "purchase",
      "inputs": [{ "name": "listingId", "type": "bytes32" }],
      "outputs": [],
      "stateMutability": "payable"
    },
    {
      "type": "function",
      "name": "confirmAndRelease",
      "inputs": [{ "name": "listingId", "type": "bytes32" }],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "cancel",
      "inputs": [{ "name": "listingId", "type": "bytes32" }],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "getListingIds",
      "inputs": [],
      "outputs": [{ "name": "", "type": "bytes32[]" }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "getListing",
      "inputs": [{ "name": "listingId", "type": "bytes32" }],
      "outputs": [
        {
          "name": "",
          "type": "tuple",
          "components": [
            { "name": "trackId", "type": "bytes32" },
            { "name": "seller", "type": "address" },
            { "name": "price", "type": "uint256" },
            { "name": "licenseType", "type": "uint8" },
            { "name": "duration", "type": "uint8" },
            { "name": "active", "type": "bool" },
            { "name": "sold", "type": "bool" },
            { "name": "createdAt", "type": "uint256" }
          ]
        }
      ],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "getPurchase",
      "inputs": [{ "name": "listingId", "type": "bytes32" }],
      "outputs": [
        {
          "name": "",
          "type": "tuple",
          "components": [
            { "name": "buyer", "type": "address" },
            { "name": "amount", "type": "uint256" },
            { "name": "confirmed", "type": "bool" },
            { "name": "purchasedAt", "type": "uint256" }
          ]
        }
      ],
      "stateMutability": "view"
    },
    {
      "type": "event",
      "name": "ListingCreated",
      "inputs": [
        { "name": "listingId", "type": "bytes32", "indexed": true },
        { "name": "trackId", "type": "bytes32", "indexed": true },
        { "name": "seller", "type": "address", "indexed": true },
        { "name": "price", "type": "uint256", "indexed": false },
        { "name": "licenseType", "type": "uint8", "indexed": false }
      ]
    },
    {
      "type": "event",
      "name": "LicensePurchased",
      "inputs": [
        { "name": "listingId", "type": "bytes32", "indexed": true },
        { "name": "buyer", "type": "address", "indexed": true },
        { "name": "amount", "type": "uint256", "indexed": false }
      ]
    },
    {
      "type": "event",
      "name": "LicenseConfirmed",
      "inputs": [{ "name": "listingId", "type": "bytes32", "indexed": true }]
    },
    {
      "type": "event",
      "name": "ListingCancelled",
      "inputs": [{ "name": "listingId", "type": "bytes32", "indexed": true }]
    },
    { "type": "error", "name": "TrackNotSealed", "inputs": [] },
    { "type": "error", "name": "NotSeller", "inputs": [] },
    { "type": "error", "name": "NotBuyer", "inputs": [] },
    { "type": "error", "name": "ListingNotActive", "inputs": [] },
    { "type": "error", "name": "AlreadySold", "inputs": [] },
    { "type": "error", "name": "WrongAmount", "inputs": [] },
    { "type": "error", "name": "AlreadyConfirmed", "inputs": [] },
    { "type": "error", "name": "TransferFailed", "inputs": [] }
  ]
}
