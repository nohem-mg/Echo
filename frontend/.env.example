# Echo frontend — the single env file for the Next.js app.
# Copy to frontend/.env.local and fill in. .env.local is gitignored — never commit secrets.
# On Vercel, set the same names in the project's Environment Variables.
# NEXT_PUBLIC_* values are baked into the client bundle at build time — never
# put secrets in them.
#
# Only secrets, per-deploy values (chain, addresses, URLs), and toggles live
# here. Tuning values (fee amount, payment description, upload cap, trigger
# timeout, world action) have code defaults — see lib/config.ts and the API
# routes — and can be overridden with the same names when needed.

# ── World ID ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_RP_ID=
NEXT_PUBLIC_WORLD_ENVIRONMENT=staging
WORLD_RP_SIGNING_KEY=
# Mock mode lets the flow run without a real proof — keep off in shared deployments.
ECHO_ENABLE_MOCK_WORLD=false
NEXT_PUBLIC_ECHO_ENABLE_MOCK_WORLD=false

# ── Registry chain ───────────────────────────────────────────────────────────
# Chain id + explorer move together (defaults: Sepolia, sepolia.etherscan.io).
NEXT_PUBLIC_REGISTRY_CHAIN_ID=11155111
NEXT_PUBLIC_REGISTRY_EXPLORER=https://sepolia.etherscan.io
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_SEPOLIA_RPC_URL=
# Server-side RPC (API routes); falls back to the public Sepolia RPC if empty.
SEPOLIA_RPC_URL=

# ── Wallet / payment gate ────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_FEE_RECEIVER_ADDRESS=
PAYMENT_RECEIVER_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_UNLINK_TOKEN_ADDRESS=
UNLINK_API_KEY=
NEXT_PUBLIC_ECHO_AGENTKIT_ENABLED=false

# ── Persistence & upload storage ─────────────────────────────────────────────
# Postgres for the flow store; empty falls back to a local JSON file (dev only —
# required on Vercel).
DATABASE_URL=
BLOB_READ_WRITE_TOKEN=

# ── Pipeline bridge (CRE / dev-gateway) ──────────────────────────────────────
CRE_TRIGGER_URL=
ECHO_GATEWAY_URL=http://127.0.0.1:8080
# Shared secret expected on pipeline start/event callbacks.
ECHO_PIPELINE_SECRET=

# ── SoundCloud publish ───────────────────────────────────────────────────────
ECHO_SOUNDCLOUD_URL=
ECHO_SOUNDCLOUD_UPLOAD_URL=
ECHO_SC_CLIENT_ID=
ECHO_SC_CLIENT_SECRET=
ECHO_SC_ACCESS_TOKEN=
ECHO_SC_REFRESH_TOKEN=
