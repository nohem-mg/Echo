# Prefix ECHO_REGISTRY_ (see app/config.py).
# Private registry (PostgreSQL). Leave empty for an in-memory store (dev/tests).
#
# Équipe — registre 2B partagé : préférer backend/.env + docker-compose.shared-registry.yml
# (Compose injecte l'URL ; pas besoin de dupliquer ici sauf run registry-service hors Docker).
# ECHO_REGISTRY_DATABASE_URL=postgresql://USER:PASS@HOST/echo_registry?sslmode=require
ECHO_REGISTRY_DATABASE_URL=
ECHO_REGISTRY_LOG_LEVEL=INFO
