# Prefix ECHO_SC_ (see app/config.py). Credentials from the SoundCloud app dashboard.
# https://developers.soundcloud.com/docs/api/guide#authentication
ECHO_SC_CLIENT_ID=
ECHO_SC_CLIENT_SECRET=

ECHO_SC_TIMEOUT_S=30
# 300 MB — SoundCloud allows up to ~5 hours of audio; 300 MB covers most lossy formats.
ECHO_SC_MAX_UPLOAD_BYTES=314572800

ECHO_SC_LOG_LEVEL=INFO
