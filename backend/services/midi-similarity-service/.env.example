# Prefix ECHO_MIDI_ (see app/config.py).
# Private registry (PostgreSQL). Leave empty for an in-memory store (dev/tests).
ECHO_MIDI_DATABASE_URL=

# Only return matches at/above this score (the CRE applies the 75 SIMILAR threshold).
ECHO_MIDI_SIMILARITY_FLOOR=10
ECHO_MIDI_TOP_N=20
ECHO_MIDI_LOG_LEVEL=INFO
