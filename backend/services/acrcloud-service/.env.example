# Prefix ECHO_ACR_ (see app/config.py). Credentials come from the ACRCloud console.
ECHO_ACR_HOST=
ECHO_ACR_ACCESS_KEY=
ECHO_ACR_ACCESS_SECRET=
ECHO_ACR_TIMEOUT_S=10
# Seconds of audio fingerprinted and sent; the rest never leaves the service.
ECHO_ACR_SAMPLE_SECONDS=20
# Also send a humming fingerprint for melodic/cover matches (needs the Humming
# bucket enabled on the ACRCloud project; harmless if it isn't).
ECHO_ACR_ENABLE_COVER=true

ECHO_ACR_MAX_UPLOAD_BYTES=52428800
ECHO_ACR_LOG_LEVEL=INFO
