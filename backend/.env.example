# Echo backend — the single env file for the dev gateway and all six microservices.
# Copy to backend/.env and fill in. backend/.env is gitignored — never commit secrets.
#
# How it is loaded:
#   - docker-compose feeds this file to every service container.
#   - A service run locally from its own directory also reads it (../../.env),
#     with an optional service-local .env overriding individual values.
#   - The gateway picks it up when run from backend/: `cd backend && bun run dev`.
#
# Only secrets, per-deploy URLs, and toggles live here. Tuning knobs (timeouts,
# upload bounds, thresholds, log levels, model names) are config values with
# defaults in each service's app/config.py — any of them can still be overridden
# here using the service prefix + field name (e.g. ECHO_ACR_TIMEOUT_S=5,
# ECHO_BP_ONSET_THRESHOLD=0.6, ECHO_SC_LOG_LEVEL=DEBUG).

# ── Gateway (:8080) ──────────────────────────────────────────────────────────
# Internal service URLs for running the gateway on the host. Under docker-compose
# these are overridden with the service-name URLs (http://basic-pitch-service:8001, …).
ECHO_BASIC_PITCH_URL=http://127.0.0.1:8001
ECHO_ACRCLOUD_URL=http://127.0.0.1:8002
ECHO_MIDI_URL=http://127.0.0.1:8003
ECHO_REGISTRY_URL=http://127.0.0.1:8004
ECHO_REPORT_URL=http://127.0.0.1:8005
ECHO_SOUNDCLOUD_URL=http://127.0.0.1:8006
# Dev conveniences: fixture-audio resolution, the Step-3 mock, the report-mock
# fallback, verbose logs. compose sets this true for local dev and false in prod.
ECHO_GATEWAY_DEV=true
# Local audio file used when the CRE simulation sends no audioRef (dev only).
ECHO_DEV_AUDIO=
# Public backend domain for the production TLS edge (docker-compose.prod.yml → Caddy).
ECHO_GATEWAY_DOMAIN=
# AgentKit payment gate on /api/report: 1 in prod/staging, 0 for CRE simulation
# (the sim carries no human credential).
ECHO_REQUIRE_AGENTKIT=1
# World Chain RPC for EIP-1271 smart-wallet signature verification.
# Optional for EOA (eip191) wallets — the SDK falls back to the public World Chain RPC.
ECHO_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public

# ── Unlink (ethereum-sepolia) ────────────────────────────────────────────────
# From your Unlink dashboard. Enables the /api/unlink/* routes.
UNLINK_API_KEY=
# Test ERC-20 the faucet uses on ethereum-sepolia (your project/environment config).
UNLINK_TEST_TOKEN=
# Optional: throwaway test mnemonic for the scratch harness. Defaults to the
# public hardhat test mnemonic if unset — testnet only.
UNLINK_TEST_MNEMONIC=
# Optional: throwaway wallet key for dev-gateway/test-agent.ts — testnet only.
PRIVATE_KEY=

# ── Optional preset bundles (PROFILES in each service's app/config.py) ───────
# One switch selects a coherent set of tuning values; explicit vars still win.
# ECHO_BP_PROFILE=sensitive|strict     (BasicPitch transcription character)
# ECHO_ACR_PROFILE=quick|thorough      (fingerprint latency vs coverage)
# ECHO_MIDI_PROFILE=strict|broad       (similarity reporting depth)
# ECHO_SC_PROFILE=demo|long_form       (upload size / upstream patience)

# ── acrcloud-service ─────────────────────────────────────────────────────────
# Credentials from the ACRCloud console.
ECHO_ACR_HOST=
ECHO_ACR_ACCESS_KEY=
ECHO_ACR_ACCESS_SECRET=

# ── registry-service ─────────────────────────────────────────────────────────
# Private registry (PostgreSQL). Leave empty for an in-memory store (dev/tests).
# docker-compose overrides this to the compose Postgres for the container.
ECHO_REGISTRY_DATABASE_URL=

# ── report-service ───────────────────────────────────────────────────────────
# Optional; empty uses deterministic fallback summaries instead of Groq.
ECHO_REPORT_GROQ_API_KEY=

# ── soundcloud-service ───────────────────────────────────────────────────────
# Credentials from the SoundCloud app dashboard:
# https://developers.soundcloud.com/docs/api/guide#authentication
ECHO_SC_CLIENT_ID=
ECHO_SC_CLIENT_SECRET=
ECHO_SC_ACCESS_TOKEN=
ECHO_SC_REFRESH_TOKEN=
