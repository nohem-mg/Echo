# Echo backend TS package (dev-gateway + Unlink + scratch harness) — env template.
# Copy to backend/.env and fill in. backend/.env is gitignored — never commit secrets.
# (Python microservices keep their own .env under services/<name>/ — this file is only
#  for the backend TS package, run from backend/ via `bun run dev-gateway/server.ts`.)

# --- Dev gateway (:8080) ---
ECHO_GATEWAY_PORT=8080
ECHO_GATEWAY_VERBOSE=1
# Internal service URLs (defaults already match docker-compose; override only if needed).
ECHO_BASIC_PITCH_URL=http://127.0.0.1:8001
ECHO_ACRCLOUD_URL=http://127.0.0.1:8002
ECHO_MIDI_URL=http://127.0.0.1:8003
ECHO_REGISTRY_URL=http://127.0.0.1:8004
ECHO_REPORT_URL=http://127.0.0.1:8005
ECHO_SOUNDCLOUD_URL=http://127.0.0.1:8006

# --- Unlink (ethereum-sepolia) ---
# From your Unlink dashboard. Enables the /api/unlink/* routes and scratch-unlink-test.ts.
UNLINK_API_KEY=
# Test ERC-20 the faucet uses on ethereum-sepolia (your project/environment config).
UNLINK_TEST_TOKEN=0x1df1077B9691A597A17B5Eb398E43efEc3CD8559
# Optional: throwaway test mnemonic for the scratch harness.
# Defaults to the public hardhat test mnemonic ("test test ... junk") if unset — testnet only.
UNLINK_TEST_MNEMONIC=
